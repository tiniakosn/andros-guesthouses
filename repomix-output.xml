@tailwind base;
@tailwind components;
@tailwind utilities;

/* --- CSS VARIABLES MAPPING --- */
body {
  /* Αντιστοιχίζουμε τη μεταβλητή του Next.js στις δικές μας font variables */
  --font-display: var(--font-sans);
  --font-serif: var(--font-sans);
  
  font-family: var(--font-sans), system-ui, sans-serif;
  background-color: #fafaf9; 
  background-image: 
    radial-gradient(at 0% 0%, rgba(132, 165, 157, 0.05) 0px, transparent 50%),
    radial-gradient(at 100% 100%, rgba(168, 162, 158, 0.1) 0px, transparent 50%);
  background-attachment: fixed;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* --- Η ΑΠΟΛΥΤΗ ΔΙΟΡΘΩΣΗ ΓΙΑ ΤΗ ΜΠΑΡΑ (OVERFLOW) --- */
html, body {
  max-width: 100% !important;
  overflow-x: hidden !important;
  position: relative;
  width: 100%;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* --- ΤΥΠΟΓΡΑΦΙΑ & CONTRAST --- */
h1, h2, h3, h4, h5, h6 {
  /* Χρήση var(--font-display) για άμεση φόρτωση (μείωση LCP delay) */
  font-family: var(--font-display), sans-serif !important;
  font-weight: 600 !important;
  letter-spacing: -0.02em !important; 
  color: #1c1917;
}

p {
  font-weight: 400;
  /* Διόρθωση Contrast: Από #57534e σε #44403c για 100/100 Accessibility */
  color: #44403c; 
  line-height: 1.8; 
}

/* --- ΔΙΑΔΡΑΣΤΙΚΑ ΣΤΟΙΧΕΙΑ --- */
::selection {
  background-color: #4d7c0f; 
  color: white;
}

input, textarea, .bg-white {
  box-shadow: 0 4px 20px -5px rgba(0,0,0,0.05) !important;
  border: 1px solid rgba(0,0,0,0.05) !important;
}

input:focus, textarea:focus {
  border-color: #65a30d !important;
  box-shadow: 0 0 0 4px rgba(101, 163, 13, 0.1) !important;
}

button {
  font-weight: 700 !important;
  letter-spacing: 0.05em !important;
}

/* --- CUSTOM SCROLLBAR (OPTIONAL) --- */
::-webkit-scrollbar {
  width: 10px;
}

::-webkit-scrollbar-track {
  background: #fafaf9;
}

::-webkit-scrollbar-thumb {
  background: #a3b18a;
  border-radius: 5px;
  border: 2px solid #fafaf9;
}

::-webkit-scrollbar-thumb:hover {
  background: #606c38;
}

/* --- UTILITIES --- */
.font-display {
  font-family: var(--font-display), sans-serif;
}

/* --- HERO ANIMATIONS (STATIC) --- */
@keyframes entrance {
  0% { transform: translateY(10px); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}

.animate-entrance {
  animation: entrance 0.3s ease-out forwards;
  will-change: transform, opacity;
}

@keyframes fadein {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.animate-fadein {
  animation: fadein 0.4s ease-out 0.1s forwards;
  opacity: 0;
}
